name: Sync to Deployment Repository

on:
  push:
    branches:
      - main
  workflow_dispatch:

jobs:
  sync:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Configure Git
        run: |
          git config --global user.email "actions@github.com"
          git config --global user.name "GitHub Actions"

      - name: Add remote and sync
        run: |
          git remote add target https://${{ secrets.MIRROR_TOKEN }}@github.com/mrghafari/sharjonv2-3f054939.git || true

          # Fetch latest state from target to avoid accidental overwrite
          git fetch target main || true

          # Push safely (prevents overwriting newer commits accidentally)
          git push target main --force-with-lease
